{
  "cypher_query": "MATCH (m:Method)\nWHERE toLower(m.name) CONTAINS toLower('bracket')\n   OR toLower(m.description) CONTAINS toLower('bracket')\nMATCH (m)-[:BELONGS_TO]->(o:Object)\nOPTIONAL MATCH (m)-[:HAS_PARAMETER]->(p:Parameter)\nOPTIONAL MATCH (p)-[:HAS_TYPE]->(pt:DataType)\nOPTIONAL MATCH (m)-[:HAS_RETURNS]->(r:ReturnValue)\nOPTIONAL MATCH (r)-[:HAS_TYPE]->(rt:DataType)\nRETURN o.name AS objectName, m.name AS methodName, m.description AS methodDescription, p.order AS parameterOrder, p.name AS parameterName, p.description AS parameterDescription, pt.name AS parameterType, r.description AS returnDescription, rt.name AS returnType\nORDER BY objectName, methodName, parameterOrder",
